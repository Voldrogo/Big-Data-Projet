## Regression

Analyse par régression : Cette méthode statistique permet de modéliser et de quantifier les relations entre les variables, facilitant ainsi la prédiction de la puissance ou du déploiement futur des bornes.

```{r Regression, eval=FALSE, include=FALSE}
library(tidyverse)
library(car)        # VIF
library(broom)
library(gridExtra)

# ── 1. NETTOYAGE & PRÉPARATION ────────────────────

# Garder seulement les top 10 opérateurs, regrouper le reste en "Autre"
top_operateurs <- names(sort(table(donnees$nom_operateur), decreasing = TRUE)[1:10])
donnees$operateur_red <- factor(
  ifelse(donnees$nom_operateur %in% top_operateurs, donnees$nom_operateur, "Autre")
)

# Supprimer les lignes avec NA sur les variables utiles
vars_modele <- c("puissance_nominale", "nbre_pdc",
                 "prise_type_ef", "prise_type_2", "prise_type_combo_ccs",
                 "prise_type_chademo", "prise_type_autre",
                 "gratuit", "paiement_acte", "paiement_cb", "paiement_autre",
                 "reservation", "station_deux_roues", "operateur_red")

donnees_clean <- donnees %>%
  select(all_of(vars_modele)) %>%
  drop_na()

cat(sprintf("✦ Observations utilisées : %d / %d\n", nrow(donnees_clean), nrow(donnees)))

# ── 2. MODÈLE COMPLET (sans GPS, sans stepAIC) ────
modele_complet <- lm(
  puissance_nominale ~
    nbre_pdc +
    prise_type_ef + prise_type_2 + prise_type_combo_ccs +
    prise_type_chademo + prise_type_autre +
    gratuit + paiement_acte + paiement_cb + paiement_autre +
    reservation + station_deux_roues +
    operateur_red,
  data = donnees_clean
)

# ── 3. SÉLECTION RAPIDE PAR P-VALUE ───────────────
# Garder uniquement les variables significatives (p < 0.05)
coefs_complet <- tidy(modele_complet) %>%
  filter(term != "(Intercept)") %>%
  # Pour les facteurs, extraire le nom de la variable de base
  mutate(var_base = gsub("operateur_red.*", "operateur_red", term)) %>%
  group_by(var_base) %>%
  summarise(p_min = min(p.value), .groups = "drop") %>%
  filter(p_min < 0.05) %>%
  pull(var_base)

cat("\n✦ Variables significatives retenues :\n")
print(coefs_complet)

# ── 4. MODÈLE FINAL ───────────────────────────────
formule_finale <- as.formula(
  paste("puissance_nominale ~", paste(coefs_complet, collapse = " + "))
)

modele_final <- lm(formule_finale, data = donnees_clean)

# ── 5. VIF sur le modèle final ────────────────────
cat("\n✦ VIF du modèle final :\n")
tryCatch({
  vif_vals <- vif(modele_final)
  print(round(vif_vals, 2))
  vars_vif_ok <- names(vif_vals[vif_vals <= 5])
  
  if (length(vars_vif_ok) < length(vif_vals)) {
    cat("\n⚠ Variables retirées (VIF > 5) :",
        paste(setdiff(names(vif_vals), vars_vif_ok), collapse = ", "), "\n")
    formule_vif <- as.formula(
      paste("puissance_nominale ~", paste(vars_vif_ok, collapse = " + "))
    )
    modele_final <- lm(formule_vif, data = donnees_clean)
  }
}, error = function(e) cat("VIF non calculable (modèle trop simple)\n"))

# ── 6. RÉSULTATS ──────────────────────────────────
cat("\n", strrep("═", 55), "\n")
cat("   RÉSULTATS DU MODÈLE FINAL\n")
cat(strrep("═", 55), "\n\n")
print(summary(modele_final))

sm <- summary(modele_final)
cat(sprintf(
  "\n  R²        = %.4f\n  R² ajusté = %.4f\n  RMSE      = %.2f\n  AIC       = %.1f\n",
  sm$r.squared,
  sm$adj.r.squared,
  sqrt(mean(residuals(modele_final)^2)),
  AIC(modele_final)
))

# ── 7. GRAPHIQUES DIAGNOSTICS ─────────────────────
donnees_diag <- augment(modele_final)

theme_custom <- theme_minimal(base_size = 11) +
  theme(
    plot.title      = element_text(face = "bold", size = 12),
    panel.grid.minor = element_blank()
  )

p1 <- ggplot(donnees_diag, aes(.fitted, .resid)) +
  geom_hline(yintercept = 0, linetype = "dashed", colour = "#e74c3c", linewidth = 0.6) +
  geom_point(alpha = 0.3, colour = "#2c3e50", size = 1.2) +
  geom_smooth(method = "loess", se = FALSE, colour = "#3498db", linewidth = 0.8) +
  labs(title = "Résidus vs Valeurs ajustées", x = "Valeurs ajustées", y = "Résidus") +
  theme_custom

p2 <- ggplot(donnees_diag, aes(sample = .std.resid)) +
  stat_qq(alpha = 0.3, colour = "#2c3e50", size = 1.2) +
  stat_qq_line(colour = "#e74c3c", linewidth = 0.7) +
  labs(title = "Q-Q Plot", x = "Quantiles théoriques", y = "Quantiles observés") +
  theme_custom

p3 <- ggplot(donnees_diag, aes(.fitted, sqrt(abs(.std.resid)))) +
  geom_point(alpha = 0.3, colour = "#2c3e50", size = 1.2) +
  geom_smooth(method = "loess", se = FALSE, colour = "#3498db", linewidth = 0.8) +
  labs(title = "Scale-Location", x = "Valeurs ajustées", y = "√|Résidus std.|") +
  theme_custom

p4 <- ggplot(donnees_diag, aes(.hat, .std.resid)) +
  geom_point(alpha = 0.3, colour = "#2c3e50", size = 1.2) +
  geom_smooth(method = "loess", se = FALSE, colour = "#3498db", linewidth = 0.8) +
  geom_vline(xintercept = 2 * mean(donnees_diag$.hat),
             linetype = "dashed", colour = "#e74c3c", linewidth = 0.6) +
  labs(title = "Résidus vs Levier", x = "Levier", y = "Résidus standardisés") +
  theme_custom

grid.arrange(p1, p2, p3, p4, ncol = 2,
             top = "Diagnostics — Modèle final")

# ── 8. IMPORTANCE DES VARIABLES ───────────────────
tidy(modele_final) %>%
  filter(term != "(Intercept)") %>%
  mutate(
    significatif = case_when(
      p.value < 0.001 ~ "***",
      p.value < 0.01  ~ "**",
      p.value < 0.05  ~ "*",
      TRUE            ~ ""
    ),
    terme = reorder(term, abs(statistic)),
    direction = ifelse(statistic > 0, "Positif", "Négatif")
  ) %>%
  ggplot(aes(x = terme, y = statistic, fill = direction)) +
  geom_col(alpha = 0.85, show.legend = TRUE) +
  geom_text(aes(label = significatif,
                hjust = ifelse(statistic > 0, -0.2, 1.2)),
            size = 3.5, fontface = "bold") +
  coord_flip() +
  scale_fill_manual(values = c("Positif" = "#27ae60", "Négatif" = "#e74c3c")) +
  labs(
    title    = "Importance des variables — t-statistique",
    subtitle = "*** p<0.001  ** p<0.01  * p<0.05",
    x = NULL, y = "t-statistique", fill = "Effet"
  ) +
  theme_minimal(base_size = 11) +
  theme(
    plot.title    = element_text(face = "bold", size = 13),
    plot.subtitle = element_text(colour = "grey50"),
    legend.position = "bottom"
  )
